# Vercel Blob — auto-injected when Blob store is connected in Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# Set to "true" in production to read/write Vercel Blob instead of local files
BLOB_STORE=

# Secret used to authenticate /api/cron/fetch requests (min 16 chars recommended)
CRON_SECRET=

# Directory for intermediate fetcher data files (use /tmp/ai-info-data on Vercel)
FETCHER_DATA_DIR=
